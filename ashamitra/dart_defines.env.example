# Flutter build-time secrets — copy to dart_defines.env and fill in values
# NEVER commit dart_defines.env to git
#
# Usage:
#   flutter run --dart-define=GEMINI_API_KEY=your_key_here
#   flutter build apk --dart-define=GEMINI_API_KEY=your_key_here
#
# Or use a .env loader script:
#   flutter run $(cat dart_defines.env | xargs -I{} echo --dart-define={})

GEMINI_API_KEY=your_gemini_api_key_here
