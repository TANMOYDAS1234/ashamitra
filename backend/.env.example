# Copy this file to .env and fill in real values. Never commit .env.

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ashamitra?retryWrites=true&w=majority

# JWT signing — use a strong random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=

# Server
PORT=5000
OTP_EXPIRY_MINUTES=10

# Pilot mode returns OTP in the response body (dev convenience). Set USE_REAL_OTP=true in prod.
PILOT_MODE=true
USE_REAL_OTP=false

# Gemini API keys (rotated round-robin if quota hits)
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# Groq (primary LLM for /api/chat)
GROQ_API_KEY=

# Google Cloud Text-to-Speech (Bengali Chirp3-HD voice)
# Get key: console.cloud.google.com → APIs & Services → Credentials → API Key
# Restrict to: Cloud Text-to-Speech API only
GOOGLE_TTS_API_KEY=
# Voice options (set GOOGLE_TTS_VOICE to one of these — bn-IN Chirp3-HD names):
#   bn-IN-Chirp3-HD-Charon   deep calm male — senior doctor (current default)
#   bn-IN-Chirp3-HD-Orus     warm narrator-style male — kind older doctor
#   bn-IN-Chirp3-HD-Kore     authoritative female — senior nurse / consultant
#   bn-IN-Chirp3-HD-Leda     calm soft female — clinical empathy (gentler)
#   bn-IN-Chirp3-HD-Aoede    warm mid-pitch female
GOOGLE_TTS_VOICE=bn-IN-Chirp3-HD-Charon
